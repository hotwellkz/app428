# API идёт через Netlify Functions (/.netlify/functions/*), отдельный backend не нужен.
# Оставьте пустым или добавьте только переменные для Netlify (например Firebase, Wazzup).

# Тест-чат автоворонок: по умолчанию POST на /.netlify/functions/crm-ai-bot-test (как остальные функции).
# Если фронт на другом домене без прокси на Netlify — задайте полный URL:
# VITE_CRM_AI_BOT_TEST_URL=https://ВАШ-ПРОЕКТ.netlify.app/.netlify/functions/crm-ai-bot-test

# --- Telegram (только Netlify / server-side, не префикс VITE_) ---
# Один бот: токен в env; разные чаты для AI-control и для складских/транзакционных уведомлений.
# TELEGRAM_BOT_TOKEN=
# AI_CONTROL_TELEGRAM_CHAT_ID=          # алерты SLA / эскалации AI-control
# TRANSACTIONS_TELEGRAM_CHAT_ID=          # опционально: приходы/переводы (/.netlify/functions/telegram-notify)

# --- Voice MVP (Netlify server-side) ---
# VOICE_PROVIDER=mock                     # mock (dev) | twilio (реальный исходящий звонок + lifecycle webhook)
# VOICE_WEBHOOK_SECRET=                   # опционально: для mock — заголовок X-Voice-Webhook-Secret или ?secret= (Twilio не использует)
# VOICE_MOCK_WEBHOOK_SECRET=              # опционально: mock JSON webhook — заголовок X-Voice-Mock-Secret
# URL / DEPLOY_PRIME_URL / VOICE_PUBLIC_SITE_URL — публичный origin сайта (TwiML + status callback)
#
# Twilio (только server-side, при VOICE_PROVIDER=twilio):
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WEBHOOK_PUBLIC_URL=              # полный URL статус-колбэка, как у Twilio (напр. https://домен/api/voice/provider-webhook) — для X-Twilio-Signature
# TWILIO_TWIML_PUBLIC_URL=                # опционально: канонический URL первого TwiML (https://домен/api/voice/twilio-twiml) — если подпись TwiML не сходится
# TWILIO_GATHER_PUBLIC_URL=               # опционально: канонический URL Gather action (https://домен/api/voice/twilio-gather-action)
# TWILIO_SKIP_SIGNATURE_VALIDATION=       # только локалка: 1 / true — не проверять подпись (не для prod)
